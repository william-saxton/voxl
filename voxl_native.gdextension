[configuration]

entry_symbol = "voxl_native_library_init"
compatibility_minimum = "4.5"
reloadable = true

[libraries]

windows.debug.x86_64 = "res://bin/libvoxl_native.windows.template_debug.x86_64.dll"
windows.release.x86_64 = "res://bin/libvoxl_native.windows.template_release.x86_64.dll"
linux.debug.x86_64 = "res://bin/libvoxl_native.linux.template_debug.x86_64.so"
linux.release.x86_64 = "res://bin/libvoxl_native.linux.template_release.x86_64.so"
